{
  "$schema": "http://json-schema.org/draft-06/schema#",
  "$ref": "#/definitions/Welcome10",
  "definitions": {
      "Welcome10": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "competitorProdRates": {
                  "$ref": "#/definitions/CompetitorProdRates"
              }
          },
          "required": [
              "competitorProdRates"
          ],
          "title": "Welcome10"
      },
      "CompetitorProdRates": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "message": {
                  "type": "string"
              },
              "status": {
                  "type": "string",
                  "format": "integer"
              },
              "rates": {
                  "type": "array",
                  "items": {
                      "$ref": "#/definitions/CompetitorProdRatesRate"
                  }
              }
          },
          "required": [
              "message",
              "rates",
              "status"
          ],
          "title": "CompetitorProdRates"
      },
      "CompetitorProdRatesRate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "rateId": {
                  "type": "string"
              },
              "productCode": {
                  "type": "string"
              },
              "banks": {
                  "type": "array",
                  "items": {
                      "$ref": "#/definitions/Bank"
                  }
              }
          },
          "required": [
              "banks",
              "productCode",
              "rateId"
          ],
          "title": "CompetitorProdRatesRate"
      },
      "Bank": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "bankName": {
                  "type": "string"
              },
              "effectiveDate": {
                  "$ref": "#/definitions/EffectiveDate"
              },
              "terms": {
                  "type": "array",
                  "items": {
                      "$ref": "#/definitions/Term"
                  }
              }
          },
          "required": [
              "bankName",
              "effectiveDate",
              "terms"
          ],
          "title": "Bank"
      },
      "Term": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "rates": {
                  "type": "array",
                  "items": {
                      "$ref": "#/definitions/TermRate"
                  }
              },
              "termId": {
                  "type": "string"
              },
              "term": {
                  "type": "integer"
              },
              "termCode": {
                  "type": "string"
              },
              "termStartDate": {
                  "anyOf": [
                      {
                          "type": "string",
                          "format": "date"
                      },
                      {
                          "type": "null"
                      }
                  ]
              },
              "termEndDate": {
                  "anyOf": [
                      {
                          "type": "string",
                          "format": "date"
                      },
                      {
                          "type": "null"
                      }
                  ]
              }
          },
          "required": [
              "rates",
              "term",
              "termCode",
              "termEndDate",
              "termId",
              "termStartDate"
          ],
          "title": "Term"
      },
      "TermRate": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
              "apr": {
                  "type": "number"
              },
              "apy": {
                  "type": "number"
              },
              "max": {
                  "type": "number"
              },
              "min": {
                  "type": "integer"
              }
          },
          "required": [
              "apr",
              "apy",
              "max",
              "min"
          ],
          "title": "TermRate"
      },
      "EffectiveDate": {
          "type": "string",
          "enum": [
              "2/16/2024",
              "02/21/2024"
          ],
          "title": "EffectiveDate"
      }
  }
}
